# Public site URL (no trailing slash) — used for canonical, OG, RSS, sitemap
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=Studio

# Admin panel (/admin) — set a strong password in local .env (never commit .env)
ADMIN_PASSWORD=change-me
# MySQL connection string for Prisma
# format: mysql://user:password@localhost:3306/blog_db
DATABASE_URL=mysql://root:password@localhost:3306/blog_db

# Optional separate secret for signing session cookies (defaults to a dev string if unset)
NUXT_ADMIN_SESSION_SECRET=

# Giscus (optional) — from https://giscus.app — only used when article frontmatter has comments: true
NUXT_PUBLIC_GISCUS_REPO=owner/repo
NUXT_PUBLIC_GISCUS_REPO_ID=
NUXT_PUBLIC_GISCUS_CATEGORY=Announcements
NUXT_PUBLIC_GISCUS_CATEGORY_ID=
NUXT_PUBLIC_GISCUS_MAPPING=pathname
NUXT_PUBLIC_GISCUS_THEME_DARK=transparent_dark
NUXT_PUBLIC_GISCUS_THEME_LIGHT=light
NUXT_PUBLIC_GISCUS_LANG=zh-CN
